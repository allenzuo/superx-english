			"description": "已学单词数",
			"bsonType": "int",
			"defaultValue": 0
		},
		"wrongQuestions": {
			"description": "错题数",
			"bsonType": "int",
			"defaultValue": 0
		},
		"streakDays": {
			"description": "连续学习天数",
			"bsonType": "int",
			"defaultValue": 0
		},
		"lastStudyDate": {
			"description": "最后学习日期",
			"bsonType": "string"
		},
		"aiCount": {
			"description": "今日AI次数",
			"bsonType": "int",
			"defaultValue": 0
		},
		"aiCountDate": {
			"description": "AI次数重置日期",
			"bsonType": "string"
		},
		"createDate": {
			"description": "创建时间",
			"bsonType": "timestamp"
		},
		"updateDate": {
			"description": "更新时间",
			"bsonType": "timestamp"
		}
	}
